# === Document Intelligence API - Example Environment ===
# Copy this file to .env and fill in your own values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/doc_intelligence

# Redis
REDIS_URL=redis://redis:6379/0

# Groq AI - Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Security - REQUIRED. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
